{
  "name": "mcp-fit",
  "version": "0.1.0",
  "description": "MCP server agent-usability scorer — scores and auto-fixes tool descriptions",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "bin": {
